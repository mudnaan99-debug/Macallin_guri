# Ku nuqul: copy this file to `.env` in backend_ci4 (ama ku dar qaybaha hoos).

CI_ENVIRONMENT = development

database.default.hostname = 127.0.0.1
database.default.database = macalin_guri
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.port = 3306

# JWT HS256 — waa inuu ahaadaa string dheer (horumar)
jwt.secret = macalin-guri-ci4-dev-secret-change-me-please-32chars-min
jwt.accessTtl = 3600
jwt.refreshTtl = 604800
