# Copy to .env and adjust. Leave DATABASE_* empty to use SQLite (dev).
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL — set DATABASE_NAME (or DJANGO_DB_ENGINE=mysql) to use MySQL instead of SQLite
# DATABASE_NAME=macalin_guri
# DATABASE_USER=root
# DATABASE_PASSWORD=
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=3306

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
